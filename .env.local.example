# ── Neon Database ─────────────────────────────────────────────
# Neon dashboard → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# ── Neon Auth ─────────────────────────────────────────────────
# Neon dashboard → Auth tab → Auth URL
NEON_AUTH_BASE_URL=https://ep-xxxx.neonauth.ap-southeast-2.aws.neon.tech/neondb/auth

# ── Resend (email) ────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Must match a verified domain in your Resend account
EMAIL_FROM=noreply@myrtlefordcommunitybus.com.au
